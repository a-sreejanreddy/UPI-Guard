# UPI Guard — Environment Variables
# Copy this file to .env and fill in all required values.

DATABASE_URL=sqlite+aiosqlite:///./upi_guard.db

# REQUIRED — generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=__REPLACE_WITH_SECURE_RANDOM_32_BYTES__
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# Cookie security — set COOKIE_SECURE=True and COOKIE_SAMESITE=strict in production (requires HTTPS)
COOKIE_SECURE=False
COOKIE_SAMESITE=lax
COOKIE_HTTPONLY=True

OTP_TTL_SECONDS=600
OTP_LENGTH=6
MODEL_PATH=models/mlp_model.h5
SCALER_PATH=models/scaler.pkl
FRONTEND_ORIGIN=http://localhost:5173
ADMIN_MOBILE=9999999999
ADMIN_NAME=Admin
