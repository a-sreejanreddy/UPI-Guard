# UPI Guard — Environment Variables
# Copy this file to .env and set your own values for production.

DATABASE_URL=sqlite+aiosqlite:///./upi_guard.db
JWT_SECRET_KEY=your-secret-key-here-use-python-secrets-token-hex-32
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60
OTP_TTL_SECONDS=600
OTP_LENGTH=6
MODEL_PATH=models/mlp_model.h5
SCALER_PATH=models/scaler.pkl
FRONTEND_ORIGIN=http://localhost:5173
ADMIN_MOBILE=9999999999
ADMIN_NAME=Admin
